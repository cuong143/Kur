local MainTab = Window:CreateTab("Fly")

-- Vars
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local flying = false
local speeds = 1              -- số luồng translate / cũng là cơ bản cho tốc độ
local speedValue = 1          -- tốc độ dùng cho BV
local tpwalking = false
local nowe = false

local ascendToggle = false    -- toggle UI
local descendToggle = false
local ascendHold = false      -- giữ phím (E)
local descendHold = false     -- giữ phím (Q)

local flyBG, flyBV, flyRenderConn

-- Helper: trạng thái ascend thực sự
local function isAscending()
	return ascendToggle or ascendHold
end
local function isDescending()
	return descendToggle or descendHold
end

-- Start/Stop translate threads (giữ nguyên logic gốc)
local function startTranslateThreads()
	tpwalking = true
	for i = 1, speeds do
		task.spawn(function()
			local hb = RunService.Heartbeat
			local char = LocalPlayer.Character
			local hum = char and char:FindFirstChildWhichIsA("Humanoid")
			while tpwalking and hb:Wait() and char and hum and hum.Parent do
				if hum.MoveDirection.Magnitude > 0 then
					-- dịch chuyển dựa trên MoveDirection (hài hòa với camera)
					char:TranslateBy(hum.MoveDirection)
				end
			end
		end)
	end
end

local function stopTranslateThreads()
	tpwalking = false
end

--Fly
local function enableFly()
	local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
	local hum = char:FindFirstChildOfClass("Humanoid")
	if not hum then return end

	nowe = true
	-- start translate threads
	startTranslateThreads()

	-- disable animate + freeze play speed
	if char:FindFirstChild("Animate") then
		char.Animate.Disabled = true
	end
	local Hum = char:FindFirstChildOfClass("Humanoid") or char:FindFirstChildOfClass("AnimationController")
	if Hum then
		for _, v in next, Hum:GetPlayingAnimationTracks() do
			v:AdjustSpeed(0)
		end
	end

	-- disable 
	local disableStates = {
		Enum.HumanoidStateType.Climbing,
		Enum.HumanoidStateType.FallingDown,
		Enum.HumanoidStateType.Flying,
		Enum.HumanoidStateType.Freefall,
		Enum.HumanoidStateType.GettingUp,
		Enum.HumanoidStateType.Jumping,
		Enum.HumanoidStateType.Landed,
		Enum.HumanoidStateType.Physics,
		Enum.HumanoidStateType.PlatformStanding,
		Enum.HumanoidStateType.Ragdoll,
		Enum.HumanoidStateType.Running,
		Enum.HumanoidStateType.RunningNoPhysics,
		Enum.HumanoidStateType.Seated,
		Enum.HumanoidStateType.StrafingNoPhysics,
		Enum.HumanoidStateType.Swimming
	}
	for _, st in ipairs(disableStates) do
		pcall(function() hum:SetStateEnabled(st, false) end)
	end
	pcall(function() hum:ChangeState(Enum.HumanoidStateType.Swimming) end)

	local jointPart
	if hum.RigType == Enum.HumanoidRigType.R6 then
		jointPart = char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso") or char:FindFirstChild("HumanoidRootPart")
	else
		jointPart = char:FindFirstChild("UpperTorso") or char:FindFirstChild("HumanoidRootPart")
	end
	if not jointPart then jointPart = char:FindFirstChildWhichIsA("BasePart") end

	flyBG = Instance.new("BodyGyro")
	flyBG.P = 9e4
	flyBG.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
	flyBG.CFrame = jointPart.CFrame
	flyBG.Parent = jointPart

	flyBV = Instance.new("BodyVelocity")
	flyBV.Velocity = Vector3.new(0, 0.1, 0)
	flyBV.MaxForce = Vector3.new(9e9, 9e9, 9e9)
	flyBV.Parent = jointPart

	--
	flyRenderConn = RunService.RenderStepped:Connect(function()
		if not nowe then return end
		local cam = workspace.CurrentCamera
		local moveDir = hum.MoveDirection or Vector3.new(0,0,0)
		local mov = Vector3.new(0,0,0)
		if moveDir.Magnitude > 0 then
			--  camera: forward/back + right/left
			mov = (cam.CFrame.LookVector * moveDir.Z + cam.CFrame.RightVector * moveDir.X) * speedValue
		end

		-- vertical velocity to toggle
		local vert = 0
		if isAscending() then vert = speedValue end
		if isDescending() then vert = -speedValue end

		-- set velocity
		if flyBV and flyBV.Parent then
			flyBV.Velocity = mov + Vector3.new(0, vert, 0)
		end

		--  orientation 
		if flyBG and flyBG.Parent then
			flyBG.CFrame = cam.CFrame * CFrame.Angles(-math.rad((moveDir.Z) * 50 * (speedValue/50)), 0, 0)
		end
	end)
end

-- off fly
local function disableFly()
	nowe = false
	stopTranslateThreads()

	-- disconnect render + destroy BV/BG
	if flyRenderConn then
		flyRenderConn:Disconnect()
		flyRenderConn = nil
	end
	if flyBG then
		pcall(function() flyBG:Destroy() end)
		flyBG = nil
	end
	if flyBV then
		pcall(function() flyBV:Destroy() end)
		flyBV = nil
	end

	local char = LocalPlayer.Character
	local hum = char and char:FindFirstChildOfClass("Humanoid")
	if hum then
		for _, st in ipairs(Enum.HumanoidStateType:GetEnumItems()) do
			pcall(function() hum:SetStateEnabled(st, true) end)
		end
		pcall(function() hum:ChangeState(Enum.HumanoidStateType.RunningNoPhysics) end)
	end

	-- enable animate
	if char and char:FindFirstChild("Animate") then
		char.Animate.Disabled = false
	end
end

-- UI: Toggle Fly
MainTab:CreateToggle({
	Name = "Fly",
	CurrentValue = false,
	Flag = "FlyToggle",
	Callback = function(Value)
		flying = Value
		if Value then
			enableFly()
		else
			disableFly()
		end
	end,
})

-- UI: Slider tốc độ
MainTab:CreateSlider({
	Name = "Speed  *note:When adjusting the speed, restart the flight to avoid errors.  ",
	Range = {1, 20},
	Increment = 1,
	CurrentValue = speedValue,
	Flag = "FlySpeed",
	Callback = function(Value)
		speedValue = Value
		speeds = math.max(1, math.floor(Value)) -- giữ gần giống GUI gốc: số luồng = speeds
		if nowe then
			stopTranslateThreads()
			startTranslateThreads()
		end
	end,
})

